---
import { Icon } from "astro-icon/components";
import StudyHeatmap from "@/components/pages/study/StudyHeatmap.svelte";
import StudyTimeline from "@/components/pages/study/StudyTimeline.svelte";
import StudyStats from "@/components/pages/study/StudyStats.svelte";
import { siteConfig, studyConfig, studyData } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.study) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.studyTitle);
const subtitle = i18n(I18nKey.studySubtitle);
const { records } = studyData;
---

<MainGridLayout title={title} description={subtitle}>
	<div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<div class="mb-8">
				<div class="flex items-center gap-3 mb-3">
					<div
						class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70"
					>
						<Icon name="material-symbols:school" class="text-[1.5rem]" />
					</div>
					<div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
						{title}
					</div>
				</div>
				<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
					{subtitle}
				</p>
			</div>

			<div class="mb-6">
				<StudyStats records={records} dailyGoal={studyConfig.dailyGoal} client:only="svelte" />
			</div>

			<div class="mb-8">
				<h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">
					<Icon name="material-symbols:calendar-month-outline" class="text-(--primary)" />
					{i18n(I18nKey.studyHeatmap)}
				</h2>
				<StudyHeatmap records={records} levels={studyConfig.heatmapLevels} client:only="svelte" />
			</div>

			<div>
				<h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-neutral-900 dark:text-neutral-100">
					<Icon name="material-symbols:timeline" class="text-(--primary)" />
					学习时间轴
				</h2>
				<StudyTimeline records={records} client:only="svelte" />
			</div>
		</div>
	</div>
</MainGridLayout>
